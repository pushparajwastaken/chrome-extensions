{
  "manifest_version": 3,
  "name": "Lumina New Tab",
  "version": "1.0.0",
  "description": "A beautiful new tab experience",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
